@{ ViewData["Title"] = "Reset Password"; }
<div class="container py-4" style="max-width:440px;">
    <div class="card shadow-sm"><div class="card-body p-4">
        <h3 class="text-center mb-4">Set New Password</h3>
        <div id="rpAlert" class="alert d-none"></div>
        <form id="rpForm">
            <input type="hidden" id="email" value="@ViewBag.Email">
            <input type="hidden" id="token" value="@ViewBag.Token">
            <div class="mb-3"><label class="form-label">New Password</label><input type="password" class="form-control" id="newPassword" required minlength="6"></div>
            <button type="submit" class="btn btn-primary w-100">Reset Password</button>
        </form>
    </div></div>
</div>
@section Scripts {
<script>
document.getElementById('rpForm').addEventListener('submit',async(e)=>{
    e.preventDefault();const alert=document.getElementById('rpAlert');
    const res=await fetch('/api/Auth/reset-password',{method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({email:document.getElementById('email').value,token:document.getElementById('token').value,
            newPassword:document.getElementById('newPassword').value})});
    const d=await res.json();
    if(res.ok){alert.className='alert alert-success';alert.textContent='Password reset! Redirecting...';setTimeout(()=>window.location.href='/Account/Login',2000);}
    else{alert.className='alert alert-danger';alert.textContent=(d.errors||[]).join(', ')||'Failed.';}
});
</script>}
