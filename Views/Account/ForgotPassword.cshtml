@{ ViewData["Title"] = "Forgot Password"; }
<div class="container py-4" style="max-width:440px;">
    <div class="card shadow-sm"><div class="card-body p-4">
        <h3 class="text-center mb-4"><i class="bi bi-key"></i> Reset Password</h3>
        <div id="fpAlert" class="alert d-none"></div>
        <form id="fpForm">
            <div class="mb-3"><label class="form-label">Email</label><input type="email" class="form-control" id="email" required></div>
            <button type="submit" class="btn btn-warning w-100">Send Reset Link</button>
        </form>
    </div></div>
</div>
@section Scripts {
<script>
document.getElementById('fpForm').addEventListener('submit',async(e)=>{
    e.preventDefault();const alert=document.getElementById('fpAlert');
    const res=await fetch('/api/Auth/forgot-password',{method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({email:document.getElementById('email').value})});
    const d=await res.json();
    alert.className='alert alert-success';alert.textContent=d.message;
    if(d.resetUrl){alert.innerHTML+=`<br><a href="${d.resetUrl}">Click here to reset (demo)</a>`;}
});
</script>}
