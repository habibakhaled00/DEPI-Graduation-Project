@{
    ViewData["Title"] = "Chat Monitor";
}

<div class="container py-4 fade-up">

    <div class="page-header mb-4">
        <div>
            <h1 class="section-title mb-1">
                <i class="bi bi-chat-dots me-2" style="color:var(--accent)"></i>Chat Monitor
            </h1>
            <p class="mb-0" style="color:var(--text-muted);font-size:0.85rem">
                View all conversations between users on the platform
            </p>
        </div>
        <a href="/Admin/Dashboard" class="quick-action-btn" style="width:auto;padding:0.5rem 1rem">
            <i class="bi bi-arrow-left"></i> Dashboard
        </a>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4" id="chatStats">
        <div class="col-12 text-center py-3"><div class="spinner-border spinner-border-sm"></div></div>
    </div>

    <!-- Search -->
    <div class="nh-card p-3 mb-3">
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" id="chatSearch" class="form-control" placeholder="Search by request title or requester…">
        </div>
    </div>

    <!-- Chat Rooms List -->
    <div id="chatRooms">
        <div class="text-center py-5"><div class="spinner-border"></div></div>
    </div>
</div>

@section Scripts {
<script>
    let allRooms = [];
    let debounce;

    document.getElementById('chatSearch').addEventListener('input', function () {
        clearTimeout(debounce);
        debounce = setTimeout(renderRooms, 250);
    });

    async function loadChatRooms() {
        const res = await fetch('/api/Admin/chats');
        if (!res.ok) { document.getElementById('chatRooms').innerHTML = '<div class="text-center py-4" style="color:var(--accent-3)">Access denied.</div>'; return; }
        allRooms = await res.json();

        // Stats
        const totalMsgs = allRooms.reduce((s, r) => s + r.messageCount, 0);
        document.getElementById('chatStats').innerHTML = [
            { icon:'bi-chat-square-dots-fill', label:'Active Rooms', value: allRooms.length, color:'var(--accent)' },
            { icon:'bi-chat-text-fill',        label:'Total Messages', value: totalMsgs,   color:'var(--accent-2)' },
        ].map(s => `
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-icon" style="color:${s.color}"><i class="bi ${s.icon}"></i></div>
                    <div class="stat-value" style="background:linear-gradient(135deg,${s.color},${s.color}99);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">${s.value}</div>
                    <div class="stat-label">${s.label}</div>
                </div>
            </div>`).join('');

        renderRooms();
    }

    function renderRooms() {
        const search = document.getElementById('chatSearch').value.toLowerCase();
        let data = allRooms;
        if (search) data = data.filter(r =>
            r.title.toLowerCase().includes(search) ||
            r.requesterName.toLowerCase().includes(search)
        );

        if (!data.length) {
            document.getElementById('chatRooms').innerHTML =
                '<div class="text-center py-5" style="color:var(--text-muted)"><i class="bi bi-chat-square fs-1 d-block mb-2"></i>No chat rooms found</div>';
            return;
        }

        const html = `<div class="row g-3 stagger">` +
            data.map(r => `
                <div class="col-md-6 col-lg-4 fade-up">
                    <a href="/Admin/Chats/${r.requestId}" class="nh-card d-block p-3 text-decoration-none" style="cursor:pointer">
                        <div class="d-flex align-items-start gap-3">
                            <div style="width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,var(--accent),var(--accent-2));display:flex;align-items:center;justify-content:center;font-size:1.1rem;color:#fff;flex-shrink:0">
                                <i class="bi bi-chat-dots-fill"></i>
                            </div>
                            <div style="flex:1;min-width:0">
                                <div style="font-weight:700;font-size:0.9rem;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${r.title}</div>
                                <div style="font-size:0.78rem;color:var(--text-secondary);margin-top:0.15rem">
                                    <i class="bi bi-person me-1"></i>${r.requesterName}
                                </div>
                                <div class="d-flex align-items-center gap-2 mt-2">
                                    <span style="background:rgba(108,99,255,0.15);color:#8b84ff;padding:0.2em 0.6em;border-radius:999px;font-size:0.7rem;font-weight:600">
                                        <i class="bi bi-chat-text me-1"></i>${r.messageCount} msg${r.messageCount !== 1 ? 's' : ''}
                                    </span>
                                    <span style="font-size:0.72rem;color:var(--text-muted)">
                                        ${timeAgo(r.lastMessage)}
                                    </span>
                                </div>
                            </div>
                            <i class="bi bi-chevron-right" style="color:var(--text-muted);margin-top:0.2rem"></i>
                        </div>
                    </a>
                </div>`).join('') + `</div>`;

        document.getElementById('chatRooms').innerHTML = html;
    }

    function timeAgo(dateStr) {
        const diff = (Date.now() - new Date(dateStr)) / 1000;
        if (diff < 60)   return 'just now';
        if (diff < 3600) return Math.floor(diff/60) + 'm ago';
        if (diff < 86400)return Math.floor(diff/3600) + 'h ago';
        return Math.floor(diff/86400) + 'd ago';
    }

    document.addEventListener('DOMContentLoaded', loadChatRooms);
</script>
}
