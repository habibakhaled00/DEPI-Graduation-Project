@{ ViewData["Title"] = "Profile"; var targetUser = ViewBag.UserId as string; }
<div class="container py-4" style="max-width:700px;">
    <div id="profileCard" class="nh-card p-4"><div class="card-body text-center py-5"><div class="spinner-border text-primary"></div></div></div>
    <div id="ratingsSection" class="mt-4"></div>
</div>
@section Scripts {
<script>
const targetUserId = "@(targetUser ?? "")";
const CurrentUID = "@(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "")";
async function loadProfile(){
    const url = targetUserId ? `/api/UserProfile/${targetUserId}` : '/api/UserProfile';
    const res = await fetch(url);
    if(!res.ok){document.getElementById('profileCard').innerHTML='<div class="card-body text-danger">Profile not found.</div>';return;}
    const p = await res.json();
    document.getElementById('profileCard').innerHTML=`
        <div class="text-center p-3">
            <i class="bi bi-person-circle display-1" style="color: var(--accent);"></i>
            <h3 class="mt-3" style="color: var(--text-primary); font-weight: 800;">${p.fullName}</h3>
            ${p.email?`<p style="color: var(--text-secondary); font-size: 0.9rem;">${p.email}</p>`:''}
            ${p.bio?`<p style="color: var(--text-muted); font-size: 0.88rem; max-width: 500px; margin: 0.75rem auto;">${p.bio}</p>`:''}
            ${p.address?`<p style="color: var(--text-muted); font-size: 0.85rem;"><i class="bi bi-geo-alt text-danger me-1"></i>${p.address}</p>`:''}
            <div class="row mt-4 justify-content-center g-3">
                <div class="col-4">
                    <h4 style="font-weight: 800; color: var(--accent-3); margin-bottom: 0.1rem;">${p.averageRating}</h4>
                    <small style="color: var(--text-muted); text-transform: uppercase; font-size: 0.72rem; letter-spacing: 0.5px;">Rating</small>
                </div>
                <div class="col-4">
                    <h4 style="font-weight: 800; color: var(--accent); margin-bottom: 0.1rem;">${p.requestsPosted}</h4>
                    <small style="color: var(--text-muted); text-transform: uppercase; font-size: 0.72rem; letter-spacing: 0.5px;">Requests</small>
                </div>
                <div class="col-4">
                    <h4 style="font-weight: 800; color: var(--accent-2); margin-bottom: 0.1rem;">${p.peopleHelped}</h4>
                    <small style="color: var(--text-muted); text-transform: uppercase; font-size: 0.72rem; letter-spacing: 0.5px;">Helped</small>
                </div>
            </div>
            ${(!targetUserId||targetUserId===CurrentUID)?'<a href="/Account/Settings" class="btn btn-outline-primary mt-4 py-2 px-4" style="font-weight: 600; border-radius: var(--radius-sm);"><i class="bi bi-gear me-1"></i> Edit Profile</a>':''}
        </div>`;
    // load ratings
    const rRes = await fetch(`/api/Ratings/user/${p.userId}`);
    if(rRes.ok){const rd=await rRes.json();
        if(rd.ratings.length>0){
            let html=`
            <div class="nh-card p-4">
                <h5 class="mb-3" style="color: var(--text-primary); font-weight: 700; font-size: 1.1rem; border-bottom: 1px solid var(--border); padding-bottom: 0.75rem;">
                    <i class="bi bi-star-fill text-warning me-2"></i>Reviews
                </h5>
                <div class="d-flex flex-column gap-3">`;
            rd.ratings.forEach(r=>{
                const stars = '★'.repeat(r.score) + '☆'.repeat(5 - r.score);
                html+=`
                <div class="p-3 rounded" style="background: rgba(255, 255, 255, 0.02); border: 1px solid var(--border);">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong style="color: var(--text-primary); font-size: 0.95rem;">${r.raterName}</strong>
                        <span class="text-warning" style="letter-spacing: 2px;">${stars}</span>
                    </div>
                    ${r.comment?`<p class="mb-1" style="color: var(--text-secondary); font-size: 0.9rem;">${r.comment}</p>`:''}
                    ${r.reviewContent?`<p class="mb-0 text-muted" style="font-size: 0.82rem;">${r.reviewContent}</p>`:''}
                </div>`;
            });
            html+='</div></div>';
            document.getElementById('ratingsSection').innerHTML=html;
        }
    }
}
document.addEventListener('DOMContentLoaded',loadProfile);
</script>}
