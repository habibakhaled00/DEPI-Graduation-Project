@{ ViewData["Title"] = "Admin Dashboard"; }
<div class="container py-4">
    <h2 class="mb-4"><i class="bi bi-shield-lock"></i> Admin Dashboard</h2>
    <div class="row mb-4" id="statsCards"></div>
    <div class="row mb-4">
        <div class="col-md-6"><div class="card shadow-sm p-3"><h5>Requests by Category</h5><canvas id="catChart" height="200"></canvas></div></div>
        <div class="col-md-6"><div class="card shadow-sm p-3"><h5>Monthly Activity</h5><canvas id="monthChart" height="200"></canvas></div></div>
    </div>
    <div class="d-flex gap-2 mb-3">
        <a href="/Admin/Users" class="btn btn-outline-primary"><i class="bi bi-people"></i> Manage Users</a>
        <a href="/Admin/Reports" class="btn btn-outline-secondary"><i class="bi bi-bar-chart"></i> Reports</a>
    </div>
</div>
@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
async function load(){
    const res=await fetch('/api/Admin/dashboard');
    if(!res.ok){alert('Admin access denied.');return;}
    const d=await res.json();
    document.getElementById('statsCards').innerHTML=
        [{l:'Users',v:d.totalUsers,c:'primary'},{l:'Requests',v:d.totalRequests,c:'success'},
         {l:'Open',v:d.openRequests,c:'info'},{l:'Completed',v:d.completedRequests,c:'secondary'},
         {l:'Avg Rating',v:d.averageRating,c:'warning'},{l:'Messages',v:d.totalMessages,c:'dark'}]
        .map(s=>`<div class="col-md-2 mb-3"><div class="card text-center p-3 text-white bg-${s.c}"><h3>${s.v}</h3><small>${s.l}</small></div></div>`).join('');
    new Chart(document.getElementById('catChart'),{type:'doughnut',
        data:{labels:d.categoryStats.map(c=>c.name),datasets:[{data:d.categoryStats.map(c=>c.count),backgroundColor:['#0d9488','#14b8a6','#f43f5e','#6366f1','#f97316','#8b5cf6','#06b6d4','#64748b']}]},
        options:{plugins:{legend:{position:'bottom'}}}});
    new Chart(document.getElementById('monthChart'),{type:'bar',
        data:{labels:d.monthlyStats.map(m=>m.month),datasets:[{label:'Requests',data:d.monthlyStats.map(m=>m.requests),backgroundColor:'#0d9488'},{label:'Completed',data:d.monthlyStats.map(m=>m.completed),backgroundColor:'#14b8a6'}]},
        options:{scales:{y:{beginAtZero:true}}}});
}
document.addEventListener('DOMContentLoaded',load);
</script>}
