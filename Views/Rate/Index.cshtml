@{ ViewData["Title"] = "Rate"; int requestId = ViewBag.RequestId; }

<div class="container py-4" style="max-width:550px;">
    <a href="/HelpRequests/Details/@requestId" class="quick-action-btn mb-3" style="width: fit-content; padding: 0.5rem 1rem;">
        <i class="bi bi-arrow-left"></i> Back to request
    </a>

    <div class="nh-card p-4">
        <div class="text-center mb-4">
            <div style="font-size:2.5rem; color: var(--accent-3);"><i class="bi bi-star-fill"></i></div>
            <h3 class="mt-2" style="color: var(--text-primary); font-weight: 800;">Rate User</h3>
            <p id="ratingTarget" style="color: var(--text-muted); font-size: 0.9rem;" class="mb-0"></p>
        </div>

        <div id="rateAlert" class="alert d-none"></div>

        <form id="rateForm">
            <input type="hidden" id="requestId" value="@requestId">
            <input type="hidden" id="ratedUserId" value="">

            <!-- Star selection -->
            <div class="mb-4 text-center">
                <label class="form-label d-block fw-bold" style="color: var(--text-secondary);">How would you rate them?</label>
                <div id="stars" class="d-flex justify-content-center gap-3 mt-2">
                    <span class="bi bi-star fs-1" style="cursor:pointer;transition:color .15s" data-v="1"></span>
                    <span class="bi bi-star fs-1" style="cursor:pointer;transition:color .15s" data-v="2"></span>
                    <span class="bi bi-star fs-1" style="cursor:pointer;transition:color .15s" data-v="3"></span>
                    <span class="bi bi-star fs-1" style="cursor:pointer;transition:color .15s" data-v="4"></span>
                    <span class="bi bi-star fs-1" style="cursor:pointer;transition:color .15s" data-v="5"></span>
                </div>
                <input type="hidden" id="score" value="0">
                <small id="scoreLabel" class="mt-2 d-block" style="color: var(--text-muted);"></small>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold" style="color: var(--text-secondary);">Quick comment</label>
                <textarea class="form-control" id="comment" rows="2" placeholder="How was the experience?"></textarea>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold" style="color: var(--text-secondary);">Detailed review <span style="color: var(--text-muted); font-weight: 400;">(optional)</span></label>
                <textarea class="form-control" id="reviewContent" rows="3" placeholder="Write a longer review if you'd like..."></textarea>
            </div>

            <button type="submit" class="btn w-100 btn-lg" id="submitBtn"
                    style="background: linear-gradient(135deg, var(--accent-3), #e69900); color: #fff; font-weight: 700; border: none; border-radius: var(--radius-sm);">
                <i class="bi bi-send me-1"></i> Submit Rating
            </button>
        </form>
    </div>
</div>

@section Scripts {
<script>
const labels = ['','Terrible','Poor','Okay','Good','Excellent'];

// get ratedUserId from URL query params
const params = new URLSearchParams(window.location.search);
const ratedUserId = params.get('userId');
const ratedUserName = params.get('name');

if(ratedUserId){
    document.getElementById('ratedUserId').value = ratedUserId;
    document.getElementById('ratingTarget').textContent = 'Rating: ' + (ratedUserName || ratedUserId);
} else {
    document.getElementById('ratingTarget').textContent = 'No user specified';
    document.getElementById('submitBtn').disabled = true;
}

// star interaction
document.querySelectorAll('#stars span').forEach(s => {
    s.addEventListener('click', () => {
        const v = +s.dataset.v;
        document.getElementById('score').value = v;
        document.getElementById('scoreLabel').textContent = labels[v] + ' (' + v + '/5)';
        updateStars(v);
    });
    s.addEventListener('mouseover', () => updateStars(+s.dataset.v));
    s.addEventListener('mouseout', () => updateStars(+document.getElementById('score').value));
});

function updateStars(val){
    document.querySelectorAll('#stars span').forEach(x => {
        x.className = +x.dataset.v <= val ? 'bi bi-star-fill fs-1 text-warning' : 'bi bi-star fs-1';
    });
}

document.getElementById('rateForm').addEventListener('submit', async(e) => {
    e.preventDefault();
    const alert = document.getElementById('rateAlert');
    const score = +document.getElementById('score').value;
    
    if(score < 1){
        alert.className = 'alert alert-danger';
        alert.textContent = 'Please select a star rating.';
        return;
    }

    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Submitting...';

    try {
        const res = await fetch('/api/Ratings', {
            method: 'POST',
            headers: {'Content-Type':'application/json'},
            body: JSON.stringify({
                ratedUserId: document.getElementById('ratedUserId').value,
                requestId: +document.getElementById('requestId').value,
                score,
                comment: document.getElementById('comment').value,
                reviewContent: document.getElementById('reviewContent').value
            })
        });
        
        if(res.ok){
            alert.className = 'alert alert-success';
            alert.textContent = 'Rating submitted! Redirecting...';
            setTimeout(() => window.location.href = '/HelpRequests/Details/' + document.getElementById('requestId').value, 1500);
        } else {
            const d = await res.text();
            alert.className = 'alert alert-danger';
            alert.textContent = d || 'Failed to submit rating.';
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-send"></i> Submit Rating';
        }
    } catch {
        alert.className = 'alert alert-danger';
        alert.textContent = 'Network error.';
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-send"></i> Submit Rating';
    }
});
</script>
}
