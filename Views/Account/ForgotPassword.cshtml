@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body > main { padding: 0 !important; margin: 0 !important; }
</style>

<div class="auth-page">
    <div class="auth-card">

        <div class="auth-logo">
            <i class="bi bi-key-fill"></i>
        </div>

        <h1 class="auth-title">Forgot Password?</h1>
        <p class="auth-subtitle">Enter your email and we'll send you a reset link</p>

        <div id="fpAlert" class="alert d-none mb-3" role="alert"></div>

        <form id="fpForm" novalidate>
            <div class="mb-4">
                <label class="form-label" for="fpEmail">Email Address</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                    <input type="email" class="form-control" id="fpEmail"
                           placeholder="you@@example.com" required autocomplete="email">
                </div>
            </div>

            <button type="submit" class="btn-nh-primary" id="fpBtn">
                <span id="fpBtnText"><i class="bi bi-send me-2"></i>Send Reset Link</span>
                <span id="fpBtnSpinner" class="d-none">
                    <span class="spinner-border spinner-border-sm me-2"></span>Sending...
                </span>
            </button>
        </form>

        <hr class="nh-divider">

        <p class="text-center mb-0" style="font-size:0.875rem;color:var(--text-muted)">
            Remembered your password?
            <a href="/Account/Login" style="font-weight:600;color:var(--accent)">Back to Login</a>
        </p>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('fpForm').addEventListener('submit', async function (e) {
        e.preventDefault();

        const alertEl = document.getElementById('fpAlert');
        const btn     = document.getElementById('fpBtn');
        const btnText = document.getElementById('fpBtnText');
        const spinner = document.getElementById('fpBtnSpinner');

        alertEl.classList.add('d-none');
        btn.disabled = true;
        btnText.classList.add('d-none');
        spinner.classList.remove('d-none');

        try {
            const res = await fetch('/api/Auth/forgot-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email: document.getElementById('fpEmail').value.trim() })
            });

            const d = await res.json();
            alertEl.className = 'alert alert-success mb-3';
            let html = d.message || 'Check your inbox for the reset link.';
            if (d.resetUrl) {
                html += `<br><a href="${d.resetUrl}" class="alert-link mt-1 d-inline-block">
                    <i class="bi bi-arrow-right me-1"></i>Click here to reset (demo)</a>`;
            }
            alertEl.innerHTML = html;
            alertEl.classList.remove('d-none');
        } catch (err) {
            alertEl.className = 'alert alert-danger mb-3';
            alertEl.textContent = 'Network error. Please try again.';
            alertEl.classList.remove('d-none');
        }

        btn.disabled = false;
        btnText.classList.remove('d-none');
        spinner.classList.add('d-none');
    });
</script>
}
