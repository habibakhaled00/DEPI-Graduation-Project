<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="NeighborHelp – Community Help Platform connecting neighbors" />
    <title>@ViewData["Title"] - NeighborHelp</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Bootstrap & Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- ── Animation: Progress Bar & Particles ──────────────── -->
    <div id="nh-progress"></div>
    <div id="nh-particles"></div>
    <button id="nh-scroll-top" title="Back to top" aria-label="Scroll to top">
        <i class="bi bi-arrow-up"></i>
    </button>

    <!-- ── Navbar ──────────────────────────────────────────────── -->
    <nav class="navbar navbar-expand-lg nh-navbar">
        <div class="container">
            <!-- Brand -->
            <a class="navbar-brand nh-brand" href="/HelpRequests">
                <i class="bi bi-people-fill me-1"></i>NeighborHelp
            </a>

            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                    style="color: var(--text-secondary);">
                <i class="bi bi-list fs-4"></i>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <!-- Left links (shown when logged in) -->
                <ul class="navbar-nav me-auto" id="navLinksLeft" style="display:none!important">
                    <li class="nav-item">
                        <a class="nav-link" href="/HelpRequests">
                            <i class="bi bi-house-door me-1"></i>Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/HelpRequests/Create">
                            <i class="bi bi-plus-circle me-1"></i>Post Request
                        </a>
                    </li>
                </ul>

                <!-- Right links -->
                <ul class="navbar-nav ms-auto align-items-center gap-1">
                    <!-- Theme Toggle -->
                    <li class="nav-item">
                        <button id="themeToggle" title="Toggle dark / light mode" aria-label="Toggle theme">
                            <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
                        </button>
                    </li>

                    <!-- Notifications (logged in) -->
                    <li class="nav-item d-none" id="navNotif">
                        <a class="nav-link position-relative" href="/Notifications">
                            <i class="bi bi-bell"></i>
                            <span id="notifBadge" class="notif-badge position-absolute top-0 start-100 translate-middle"
                                  style="display:none"></span>
                        </a>
                    </li>

                    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                    {
                        <!-- Admin dropdown (logged in + admin role) -->
                        <li class="nav-item dropdown" id="navAdmin">
                            <a class="nav-link admin-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-shield-lock me-1"></i>Admin
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:var(--radius-sm);min-width:180px">
                                <li><a class="dropdown-item" href="/Admin/Dashboard" style="color:var(--text-primary);font-size:0.875rem;padding:0.55rem 1rem">
                                    <i class="bi bi-grid me-2" style="color:var(--accent)"></i>Dashboard</a></li>
                                <li><a class="dropdown-item" href="/Admin/Users" style="color:var(--text-primary);font-size:0.875rem;padding:0.55rem 1rem">
                                    <i class="bi bi-people me-2" style="color:var(--accent-2)"></i>Users</a></li>
                                <li><a class="dropdown-item" href="/Admin/Requests" style="color:var(--text-primary);font-size:0.875rem;padding:0.55rem 1rem">
                                    <i class="bi bi-card-list me-2" style="color:#ffaa00"></i>Requests</a></li>
                                <li><a class="dropdown-item" href="/Admin/Chats" style="color:var(--text-primary);font-size:0.875rem;padding:0.55rem 1rem">
                                    <i class="bi bi-chat-dots me-2" style="color:#8b84ff"></i>Chat Monitor</a></li>
                                <li><hr class="dropdown-divider" style="border-color:var(--border);margin:0.25rem 0"></li>
                                <li><a class="dropdown-item" href="/Admin/Reports" style="color:var(--text-primary);font-size:0.875rem;padding:0.55rem 1rem">
                                    <i class="bi bi-bar-chart me-2" style="color:var(--accent-3)"></i>Reports</a></li>
                            </ul>
                        </li>
                    }

                    <!-- Profile (logged in) -->
                    <li class="nav-item d-none" id="navProfile">
                        <a class="nav-link" href="/Account/Profile">
                            <i class="bi bi-person-circle me-1"></i>
                            <span id="navUserName">Profile</span>
                        </a>
                    </li>

                    <!-- Logout (logged in) -->
                    <li class="nav-item d-none" id="navLogout">
                        <a class="nav-link" href="#" onclick="doLogout(event)">
                            <i class="bi bi-box-arrow-right me-1"></i>Logout
                        </a>
                    </li>

                    <!-- Login / Register (logged out) -->
                    <li class="nav-item" id="navLogin">
                        <a class="nav-link" href="/Account/Login">Login</a>
                    </li>
                    <li class="nav-item" id="navRegister">
                        <a class="btn btn-primary btn-sm px-3 py-1" href="/Account/Register">Register</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- ── Main Content ────────────────────────────────────────── -->
    <main class="container mt-4 mb-5">
        @RenderBody()
    </main>

    <!-- ── Footer ─────────────────────────────────────────────── -->
    <footer class="nh-footer">
        <div class="container text-center">
            <p class="mb-0">
                <i class="bi bi-people-fill me-1" style="color:var(--accent)"></i>
                &copy; 2026 <strong>NeighborHelp</strong> — Community Help Platform
                <span class="mx-2" style="opacity:0.3">|</span>
                GIU Capstone Project
            </p>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- SignalR -->
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@latest/dist/browser/signalr.min.js"></script>

    <script>
        /* ── Theme Toggle ──────────────────────────────────────── */
        (function () {
            const saved = localStorage.getItem('nh-theme') || 'dark';
            document.documentElement.setAttribute('data-theme', saved);
            updateThemeIcon(saved);
        })();

        function updateThemeIcon(theme) {
            const icon = document.getElementById('themeIcon');
            if (!icon) return;
            icon.className = theme === 'dark' ? 'bi bi-sun-fill' : 'bi bi-moon-stars-fill';
        }

        document.getElementById('themeToggle').addEventListener('click', function () {
            const current = document.documentElement.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('nh-theme', next);
            updateThemeIcon(next);
        });

        /* ── Nav Auth Update ───────────────────────────────────── */
        async function updateNav() {
            try {
                const res = await fetch('/api/UserProfile');
                if (res.ok) {
                    const user = await res.json();

                    // show authenticated nav items
                    document.getElementById('navLinksLeft').style.removeProperty('display');
                    document.getElementById('navProfile').classList.remove('d-none');
                    document.getElementById('navLogout').classList.remove('d-none');
                    document.getElementById('navNotif').classList.remove('d-none');
                    document.getElementById('navLogin').classList.add('d-none');
                    document.getElementById('navRegister').classList.add('d-none');
                    document.getElementById('navUserName').textContent = user.fullName.split(' ')[0];



                    // unread notifications
                    const nRes = await fetch('/api/NotificationsApi/unread-count');
                    if (nRes.ok) {
                        const nd = await nRes.json();
                        if (nd.count > 0) {
                            const b = document.getElementById('notifBadge');
                            b.textContent = nd.count;
                            b.style.display = 'inline-block';
                        }
                    }

                    // SignalR
                    const conn = new signalR.HubConnectionBuilder().withUrl("/hubs/notifications").build();
                    conn.on("ReceiveNotification", function () {
                        const b = document.getElementById('notifBadge');
                        let c = parseInt(b.textContent || '0') + 1;
                        b.textContent = c;
                        b.style.display = 'inline-block';
                    });
                    conn.start().catch(() => { });
                }
            } catch (e) { }
        }

        async function doLogout(e) {
            e.preventDefault();
            await fetch('/api/Auth/logout', { method: 'POST' });
            window.location.href = '/Account/Login';
        }

        document.addEventListener('DOMContentLoaded', updateNav);
    </script>

    <!-- Animations -->
    <script src="~/js/animations.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
