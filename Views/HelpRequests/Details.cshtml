@{
    ViewData["Title"] = "Request Details";
    int requestId = ViewBag.RequestId;
}

<div class="container py-4" style="max-width: 800px;">
    <a asp-controller="HelpRequests" asp-action="Index" class="quick-action-btn mb-3" style="width: fit-content; padding: 0.5rem 1rem;">
        <i class="bi bi-arrow-left"></i> Back to board
    </a>

    <div id="detailsCard" class="nh-card p-4">
        <div class="text-center py-5" id="loadingSpinner">
            <div class="spinner-border" style="color:var(--accent)"></div>
        </div>
    </div>

    <div id="actionArea" class="mt-3 d-flex gap-2 flex-wrap"></div>

    <!-- Ratings section loaded by JS -->
    <div id="ratingsSection"></div>
</div>

@section Scripts {
    <script>const requestId = @requestId;</script>
    <script src="~/js/requestDetails.js" asp-append-version="true"></script>
}
