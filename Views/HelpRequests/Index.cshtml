@{
    ViewData["Title"] = "Community Board";
    var categories = ViewBag.Categories as List<NeighborHelp.Models.Category>;
}

<div class="container py-4 fade-up">

    <!-- Hero Banner -->
    <div style="background:linear-gradient(135deg,rgba(108,99,255,0.15) 0%,rgba(0,212,170,0.1) 100%);
                border:1px solid var(--border);border-radius:var(--radius);padding:2rem;
                margin-bottom:1.5rem;position:relative;overflow:hidden">
        <!-- Decorative blobs -->
        <div style="position:absolute;width:200px;height:200px;border-radius:50%;
                    background:rgba(108,99,255,0.15);filter:blur(60px);
                    top:-60px;right:-40px;pointer-events:none"></div>
        <div style="position:absolute;width:150px;height:150px;border-radius:50%;
                    background:rgba(0,212,170,0.12);filter:blur(50px);
                    bottom:-40px;left:20%;pointer-events:none"></div>

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3" style="position:relative;z-index:1">
            <div>
                <h1 style="font-size:1.8rem;font-weight:800;margin-bottom:0.3rem">
                    <span style="background:linear-gradient(135deg,var(--accent),var(--accent-2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">Community</span>
                    Help Board 🤝
                </h1>
                <p class="mb-0" style="color:var(--text-muted);font-size:0.9rem">
                    Browse requests and volunteer to help your neighbors
                </p>
            </div>
            <a asp-controller="HelpRequests" asp-action="Create"
               style="background:linear-gradient(135deg,var(--accent),#8b7ff0);border:none;color:#fff;
                      font-weight:600;font-size:0.875rem;padding:0.65rem 1.5rem;border-radius:var(--radius-sm);
                      text-decoration:none;display:inline-flex;align-items:center;gap:0.5rem;
                      transition:all 0.25s;box-shadow:0 4px 20px rgba(108,99,255,0.3)"
               onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 30px rgba(108,99,255,0.45)'"
               onmouseout="this.style.transform='';this.style.boxShadow='0 4px 20px rgba(108,99,255,0.3)'">
                <i class="bi bi-plus-circle"></i> Post a Request
            </a>
        </div>
    </div>

    <!-- Filters -->
    <div class="nh-card p-3 mb-4">
        <div class="row g-2">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" id="searchInput" class="form-control"
                           placeholder="Search by title, description or address…">
                </div>
            </div>
            <div class="col-md-3">
                <select id="categoryFilter" class="form-select">
                    <option value="">All Categories</option>
                    @if (categories != null)
                    {
                        foreach (var c in categories)
                        {
                            <option value="@c.CategoryId">@c.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select id="statusFilter" class="form-select">
                    <option value="">All Statuses</option>
                    <option value="Open">Open</option>
                    <option value="Pending">Pending</option>
                    <option value="Accepted">Accepted</option>
                    <option value="Rejected">Rejected</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Loading -->
    <div id="loadingIndicator" class="text-center py-5 d-none">
        <div class="spinner-border" role="status"></div>
        <p class="mt-2" style="color:var(--text-muted)">Loading requests…</p>
    </div>

    <!-- Empty State -->
    <div id="emptyState" class="text-center py-5 d-none">
        <i class="bi bi-inbox" style="font-size:3rem;color:var(--text-muted)"></i>
        <p class="mt-3" style="color:var(--text-muted)">No requests found. Be the first to post one!</p>
        <a asp-controller="HelpRequests" asp-action="Create" class="btn btn-primary mt-2">
            <i class="bi bi-plus-circle me-2"></i>Post a Request
        </a>
    </div>

    <!-- Cards Grid -->
    <div id="requestsContainer" class="row g-3 stagger"></div>

    <!-- Pagination -->
    <nav class="mt-4" id="paginationNav">
        <ul class="pagination justify-content-center" id="pagination"></ul>
    </nav>
</div>

<!-- Card Template -->
<template id="requestCardTemplate">
    <div class="col-md-4">
        <div class="nh-card h-100" style="display:flex;flex-direction:column;padding:1.25rem">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <h5 class="req-title mb-0" style="font-size:1rem;font-weight:700;color:var(--text-primary)"></h5>
                <span class="req-status-badge" style="white-space:nowrap;margin-left:0.5rem"></span>
            </div>
            <p class="req-category mb-2" style="font-size:0.75rem;color:var(--accent);font-weight:600;text-transform:uppercase;letter-spacing:0.06em"></p>
            <p class="req-description" style="font-size:0.875rem;color:var(--text-secondary);flex:1;overflow:hidden;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;"></p>
            <hr class="nh-divider my-2">
            <p class="mb-2" style="font-size:0.78rem;color:var(--text-muted)">
                <i class="bi bi-geo-alt me-1"></i><span class="req-address"></span>
            </p>
            <p class="req-meta mb-3" style="font-size:0.75rem;color:var(--text-muted)"></p>
            <div class="d-flex gap-2 mt-auto">
                <a href="#" class="btn btn-outline-secondary btn-sm req-details-btn flex-grow-1">
                    <i class="bi bi-eye me-1"></i>View
                </a>
                <button class="btn btn-success btn-sm req-volunteer-btn flex-grow-1">
                    <i class="bi bi-hand-thumbs-up me-1"></i>Volunteer
                </button>
            </div>
        </div>
    </div>
</template>

@section Scripts {
    <script>
        window.CurrentUID = "@(User.Identity != null && User.Identity.IsAuthenticated ? User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value : "")";
    </script>
    <script src="~/js/requestsBoard.js" asp-append-version="true"></script>
}
