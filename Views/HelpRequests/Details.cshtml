@{
    ViewData["Title"] = "Request Details";
    int requestId = ViewBag.RequestId;
}

<div class="container py-4" style="max-width: 800px;">
    <a asp-controller="HelpRequests" asp-action="Index" class="btn btn-link ps-0 mb-3">
        <i class="bi bi-arrow-left"></i> Back to board
    </a>

    <div id="detailsCard" class="card shadow-sm">
        <div class="card-body">
            <div class="text-center py-5" id="loadingSpinner">
                <div class="spinner-border text-primary"></div>
            </div>
        </div>
    </div>

    <div id="actionArea" class="mt-3 d-flex gap-2"></div>
</div>

@section Scripts {
    <script>
        const requestId = @requestId;
        const CurrentUID = "@(User.Identity != null && User.Identity.IsAuthenticated ? User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value : "")";
    </script>
    <script src="~/js/requestDetails.js" asp-append-version="true"></script>
}
