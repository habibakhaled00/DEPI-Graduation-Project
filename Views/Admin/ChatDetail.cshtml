@model int
@{
    ViewData["Title"] = "Chat Viewer";
    int requestId = Model;
}

<div class="container py-4 fade-up" style="max-width:820px">

    <div class="d-flex align-items-center gap-2 mb-4">
        <a href="/Admin/Chats" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
        <div>
            <span style="font-size:0.78rem;color:var(--text-muted)">Admin Chat Viewer</span>
            <h1 class="section-title mb-0" id="chatTitle" style="font-size:1.3rem">Loading…</h1>
        </div>
    </div>

    <!-- Request Info Card -->
    <div class="nh-card p-3 mb-4" id="requestInfo" style="display:none">
        <div class="d-flex align-items-center gap-3">
            <div style="width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,var(--accent),var(--accent-2));display:flex;align-items:center;justify-content:center;font-size:1.1rem;color:#fff;flex-shrink:0">
                <i class="bi bi-card-text"></i>
            </div>
            <div>
                <div id="reqTitle" style="font-weight:700;color:var(--text-primary)"></div>
                <div id="reqRequester" style="font-size:0.8rem;color:var(--text-secondary)"></div>
            </div>
            <div class="ms-auto d-flex gap-2">
                <a id="viewReqLink" href="#" class="btn btn-outline-secondary btn-sm" target="_blank">
                    <i class="bi bi-eye me-1"></i>View Request
                </a>
            </div>
        </div>
    </div>

    <!-- Admin Notice -->
    <div class="alert" style="background:rgba(108,99,255,0.1);border:1px solid rgba(108,99,255,0.2);color:var(--text-secondary);border-radius:var(--radius-sm);font-size:0.82rem;margin-bottom:1rem">
        <i class="bi bi-shield-lock me-2" style="color:var(--accent)"></i>
        <strong style="color:var(--accent)">Admin Read-Only View</strong> — You are viewing this conversation as an administrator. Users cannot see that you are here.
    </div>

    <!-- Messages -->
    <div class="nh-card p-0" style="overflow:hidden">
        <div style="padding:1rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between">
            <span style="font-size:0.82rem;color:var(--text-secondary);font-weight:600">
                <i class="bi bi-chat-dots me-2" style="color:var(--accent)"></i>
                <span id="msgCountLabel">Messages</span>
            </span>
            <button class="btn btn-outline-secondary btn-sm" onclick="loadChat()">
                <i class="bi bi-arrow-clockwise"></i> Refresh
            </button>
        </div>

        <div id="chatWindow" style="min-height:400px;max-height:60vh;overflow-y:auto;padding:1.25rem;background:var(--bg-secondary)">
            <div class="text-center py-5"><div class="spinner-border"></div></div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const requestId = @requestId;

    async function loadChat() {
        const res = await fetch(`/api/Admin/chats/${requestId}`);
        if (!res.ok) {
            document.getElementById('chatWindow').innerHTML =
                '<div class="text-center py-4" style="color:var(--accent-3)">Could not load messages.</div>';
            return;
        }

        const data = await res.json();

        // Update header
        document.getElementById('chatTitle').textContent = data.requestTitle;
        document.getElementById('reqTitle').textContent = data.requestTitle;
        document.getElementById('reqRequester').innerHTML = `<i class="bi bi-person me-1"></i>Requested by ${data.requesterName}`;
        document.getElementById('viewReqLink').href = `/HelpRequests/Details/${data.requestId}`;
        document.getElementById('requestInfo').style.display = '';
        document.getElementById('msgCountLabel').textContent = `${data.messages.length} message${data.messages.length !== 1 ? 's' : ''}`;

        if (!data.messages.length) {
            document.getElementById('chatWindow').innerHTML =
                '<div class="text-center py-5" style="color:var(--text-muted)"><i class="bi bi-chat-square fs-2 d-block mb-2"></i>No messages yet</div>';
            return;
        }

        // Build unique senders → assign colors
        const senders = [...new Set(data.messages.map(m => m.senderId))];
        const palette = ['var(--accent)', 'var(--accent-2)', '#ffaa00', 'var(--accent-3)', '#8b5cf6', '#06b6d4'];
        const colorMap = {};
        senders.forEach((id, i) => colorMap[id] = palette[i % palette.length]);

        let html = '';
        let lastDate = '';

        data.messages.forEach(m => {
            const msgDate = new Date(m.sentAt).toLocaleDateString();
            if (msgDate !== lastDate) {
                html += `<div class="text-center my-3">
                    <span style="font-size:0.72rem;color:var(--text-muted);background:var(--bg-card);padding:0.25em 1em;border-radius:999px;border:1px solid var(--border)">
                        ${msgDate}
                    </span>
                </div>`;
                lastDate = msgDate;
            }

            const color = colorMap[m.senderId];
            const time  = new Date(m.sentAt).toLocaleTimeString([], { hour:'2-digit', minute:'2-digit' });

            html += `<div style="margin-bottom:1rem">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <div style="width:28px;height:28px;border-radius:50%;background:${color}22;border:2px solid ${color};display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;color:${color}">
                        ${m.senderName.charAt(0).toUpperCase()}
                    </div>
                    <span style="font-size:0.8rem;font-weight:600;color:${color}">${m.senderName}</span>
                    <span style="font-size:0.7rem;color:var(--text-muted)">${time}</span>
                </div>
                <div style="margin-left:36px;background:var(--bg-card);border:1px solid var(--border);border-radius:0 12px 12px 12px;padding:0.6rem 0.9rem;font-size:0.875rem;color:var(--text-primary);max-width:80%;word-wrap:break-word">
                    ${escapeHtml(m.content)}
                </div>
            </div>`;
        });

        const win = document.getElementById('chatWindow');
        win.innerHTML = html;
        win.scrollTop = win.scrollHeight;
    }

    function escapeHtml(text) {
        return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    document.addEventListener('DOMContentLoaded', loadChat);
</script>
}
