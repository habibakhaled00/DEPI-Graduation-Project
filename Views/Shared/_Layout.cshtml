<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NeighborHelp</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/"><i class="bi bi-people-fill"></i> NeighborHelp</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/"><i class="bi bi-house"></i> Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/HelpRequests/Create"><i class="bi bi-plus-circle"></i> Post Request</a></li>
                </ul>
                <ul class="navbar-nav" id="authNav">
                    <li class="nav-item d-none" id="navNotif">
                        <a class="nav-link" href="/Notifications"><i class="bi bi-bell"></i> <span id="notifBadge" class="badge bg-danger" style="display:none"></span></a>
                    </li>
                    <li class="nav-item d-none" id="navAdmin">
                        <a class="nav-link text-warning" href="/Admin/Dashboard"><i class="bi bi-shield-lock"></i> Admin</a>
                    </li>
                    <li class="nav-item d-none" id="navProfile">
                        <a class="nav-link" href="/Account/Profile"><i class="bi bi-person"></i> <span id="navUserName">Profile</span></a>
                    </li>
                    <li class="nav-item d-none" id="navLogout">
                        <a class="nav-link" href="#" onclick="doLogout()"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    </li>
                    <li class="nav-item" id="navLogin">
                        <a class="nav-link" href="/Account/Login">Login</a>
                    </li>
                    <li class="nav-item" id="navRegister">
                        <a class="nav-link" href="/Account/Register">Register</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container mt-4 mb-5">
        @RenderBody()
    </main>

    <footer class="bg-dark text-light py-3 mt-auto">
        <div class="container text-center">
            <p class="mb-0">&copy; 2026 NeighborHelp - Community Help Platform | GIU Capstone Project</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@latest/dist/browser/signalr.min.js"></script>
    <script>
        // check if user is logged in and update nav
        async function updateNav(){
            try{
                const res = await fetch('/api/UserProfile');
                if(res.ok){
                    const user = await res.json();
                    document.getElementById('navProfile').classList.remove('d-none');
                    document.getElementById('navLogout').classList.remove('d-none');
                    document.getElementById('navNotif').classList.remove('d-none');
                    document.getElementById('navLogin').classList.add('d-none');
                    document.getElementById('navRegister').classList.add('d-none');
                    document.getElementById('navUserName').textContent = user.fullName.split(' ')[0];
                    
                    // check if admin
                    const adminRes = await fetch('/api/Admin/dashboard');
                    if(adminRes.ok) document.getElementById('navAdmin').classList.remove('d-none');
                    
                    // unread notifications
                    const nRes = await fetch('/api/NotificationsApi/unread-count');
                    if(nRes.ok){const nd=await nRes.json();
                        if(nd.count>0){const b=document.getElementById('notifBadge');b.textContent=nd.count;b.style.display='inline';}}

                    // signalr
                    const conn = new signalR.HubConnectionBuilder().withUrl("/hubs/notifications").build();
                    conn.on("ReceiveNotification", function(msg){
                        const b=document.getElementById('notifBadge');
                        let c=parseInt(b.textContent||'0')+1;b.textContent=c;b.style.display='inline';
                    });
                    conn.start().catch(()=>{});
                }
            }catch(e){}
        }
        
        async function doLogout(){
            await fetch('/api/Auth/logout',{method:'POST'});
            window.location.href='/Account/Login';
        }
        
        document.addEventListener('DOMContentLoaded', updateNav);
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
